(export-to "jsonc")
(@DEVICE (get-env-var "DEVICE"))

((@device
    ((if
        (eq DEVICE "LAPTOP")
            ("LAPTOP")
            ("DESKTOP"))))
(@users
    ("test" "test2" "test3"))
(@password "test"))

